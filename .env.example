# Copy this file to .env and fill in your keys.
# .env is git-ignored; never commit real keys.

# Semantic Scholar API key (optional — without it requests are rate-limited)
# Apply at: https://www.semanticscholar.org/product/api
S2_API_KEY=

# DeepSeek API key (required for keyword extraction step)
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API key (optional alternative provider)
# https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Zhipu GLM API key (required for post-search relevance filtering)
# https://open.bigmodel.cn/
GLM_API_KEY=
GLM_MODEL=GLM-4.7-FlashX
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_THINKING_TYPE=disabled


